# PostgreSQL (usado pelo docker compose; a app ainda não consulta o banco)
POSTGRES_USER=gaia
POSTGRES_PASSWORD=gaia
POSTGRES_DB=gaia_uel
# Host "db" = nome do serviço no docker compose (rede padrão)
DATABASE_URL=postgresql://gaia:gaia@db:5432/gaia_uel

# Chave geral do módulo de e-mail. Enquanto for "false" (padrão), a seção de
# contato, os botões/links relacionados e a rota /api/contact ficam
# desativados em todo o site. Troque para "true" somente depois de configurar
# as variáveis SMTP abaixo.
USE_MAIL=false

# Credenciais SMTP usadas pela rota /api/contact (Nodemailer)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password

# Caixa de entrada que recebe as mensagens do formulário de contato
CONTACT_TO_EMAIL=contato@gaia-uel.com.br

# Endereço de envio dos e-mails. Usa SMTP_USER como padrão, se não for definido.
CONTACT_FROM_EMAIL=no-reply@gaia-uel.com.br
