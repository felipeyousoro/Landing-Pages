# SQLite database (Drizzle). Relative paths resolve from the project root.
DATABASE_URL=file:./data/dazco.db

# Public site URL used for canonical links, Open Graph, sitemap, and JSON-LD
NEXT_PUBLIC_SITE_URL=https://www.dazco.ae

# Optional public contact email for structured data (JSON-LD)
# NEXT_PUBLIC_CONTACT_EMAIL=info@dazco.ae

# Optional Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX).
# When set, a cookie consent banner is shown and GA loads only after Accept.
# NEXT_PUBLIC_GA_MEASUREMENT_ID=

# SMTP credentials used by the /api/contact route (Nodemailer)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password

# Where contact form submissions are delivered to
CONTACT_TO_EMAIL=you@dazco.com

# Sender address for outgoing emails. Defaults to SMTP_USER if not set.
CONTACT_FROM_EMAIL=no-reply@dazco.com
